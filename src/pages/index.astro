---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import { projects } from "../data/projects.js";

const isDefined = <T,>(value: T | undefined): value is T => value !== undefined;

const featuredProjects = ["trolley", "range"]
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter(isDefined);
const homeApps = projects.filter((project) => project.category === "Home Apps");
const websites = projects.filter((project) => project.category === "Websites");
const embeddedTools = projects.filter(
  (project) => project.category === "Embedded Website Tools",
);
const prototypes = projects.filter(
  (project) => project.category === "Prototype",
);
---

<BaseLayout>
  <div class="page-shell">
    <section class="hero">
      <div class="hero__content">
        <p class="eyebrow">Portfolio / Practical Projects / Real Problems</p>
        <h1>Useful websites and private apps built around real life.</h1>
        <p class="hero__lead">
          A growing portfolio of practical projects — from household planning
          and glucose logging to football archives and embedded retail website
          tools.
        </p>

        <div class="hero__actions">
          <a class="button button--primary" href="#featured-projects"
            >View projects</a
          >
          <a class="button button--secondary" href="#about">About me</a>
        </div>
      </div>

      <aside class="hero-panel" aria-label="Portfolio summary">
        <div>
          <span class="hero-panel__number">05</span>
          <span class="hero-panel__label"
            >strong portfolio pieces ready now</span
          >
        </div>
        <div>
          <span class="hero-panel__number">03</span>
          <span class="hero-panel__label"
            >home apps solving family problems</span
          >
        </div>
        <div>
          <span class="hero-panel__number">01</span>
          <span class="hero-panel__label"
            >community database prototype next</span
          >
        </div>
      </aside>
    </section>

    <section id="about" class="section about-section">
      <div class="section-heading">
        <p class="eyebrow">About</p>
        <h2>I build practical tools that make awkward jobs easier.</h2>
      </div>

      <div class="about-grid">
        <div class="about-copy">
          <p>
            I’m Ross Lyall, a manager of a Glasgow kilt shop who has gradually
            moved from fixing day-to-day process problems into designing and
            building proper web apps, internal tools and useful websites.
          </p>

          <p>
            Most of my projects start with a real problem: planning meals,
            tracking glucose patterns, organising retail workflows, improving
            customer journeys, or turning messy information into something
            easier to use.
          </p>

          <p>
            I use AI as part of how I build apps and websites, mainly for
            coding, planning and working through problems. I do not use it for
            image or video generation, and I try to use it as responsibly and
            honestly as I can. If you are firmly against AI being used in this
            kind of work, this probably is not the portfolio for you.
          </p>

          <p>
            I like building things that are clear, useful and grounded in how
            people actually work — not just polished demos that look good but
            never get used.
          </p>
        </div>

        <div class="about-card">
          <h3>What I focus on</h3>
          <ul>
            <li>Private household apps</li>
            <li>Small business workflow tools</li>
            <li>Health and data dashboards</li>
            <li>Static websites and archives</li>
            <li>Embedded website tools</li>
            <li>AI-assisted app building</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section build-section">
      <div class="section-heading">
        <p class="eyebrow">What I build</p>
        <h2>Real-world tools, not imaginary apps.</h2>
        <p>
          The strongest projects here come from actual needs — shopping, health
          logging, football archiving, retail customer journeys and community
          admin.
        </p>
      </div>
    </section>

    <section id="featured-projects" class="section featured-section">
      <span id="projects" class="section-anchor" aria-hidden="true"></span>
      <div class="section-heading">
        <p class="eyebrow">Featured projects</p>
        <h2>Portfolio pieces ready to show</h2>
        <p>
          These are the projects that best show the mix of design, data,
          workflow thinking and real-world usefulness.
        </p>
      </div>

      <div class="featured-projects-grid">
        {
          featuredProjects.map((project) => (
            <article
              class={`project-card project-card--${project.theme} featured-project-row`}
            >
              <div class="featured-project-row__content">
                <div class="project-visual" aria-hidden="true">
                  <span class="project-visual__orb" />
                  <span class="project-visual__line" />
                  <span class="project-visual__line project-visual__line--short" />
                </div>

                <div class="featured-project-row__body">
                  <div class="project-card__body">
                    <div class="project-card__top">
                      <span class="project-category">{project.category}</span>
                      <span class="project-status">{project.status}</span>
                    </div>

                    <h3>{project.title}</h3>
                    <p class="project-type">{project.type}</p>
                    <p class="project-description">{project.description}</p>

                    <div
                      class="tech-list"
                      aria-label={`Technologies used for ${project.title}`}
                    >
                      {project.tech.map((item: string) => (
                        <span>{item}</span>
                      ))}
                    </div>

                    <div class="project-actions">
                      {project.links?.caseStudy && (
                        <a
                          class="project-link project-link--primary"
                          href={project.links.caseStudy}
                        >
                          Read case study
                        </a>
                      )}

                      {project.links?.live &&
                        !Array.isArray(project.links.live) && (
                          <a
                            class="project-link"
                            href={project.links.live}
                            target="_blank"
                            rel="noreferrer"
                          >
                            Live site
                          </a>
                        )}

                      {project.links?.privateLabel && (
                        <span
                          class="project-link project-link--disabled"
                          aria-disabled="true"
                        >
                          {project.links.privateLabel}
                        </span>
                      )}
                    </div>
                  </div>

                  {project.slug === "trolley" && (
                    <div
                      class="featured-teasers"
                      aria-label="Trolley screenshot teasers"
                    >
                      <div class="featured-teaser featured-teaser--offset">
                        <img
                          src="/images/projects/trolley/list.png"
                          alt="Trolley shopping list screenshot"
                          loading="lazy"
                        />
                      </div>
                      <div class="featured-teaser">
                        <img
                          src="/images/projects/trolley/planner.png"
                          alt="Trolley meal planner screenshot"
                          loading="lazy"
                        />
                      </div>
                    </div>
                  )}

                  {project.slug === "range" && (
                    <div
                      class="featured-teasers"
                      aria-label="Range screenshot teasers"
                    >
                      <div class="featured-teaser featured-teaser--offset">
                        <img
                          src="/images/projects/range/image2.png"
                          alt="Range mobile glucose chart screenshot"
                          loading="lazy"
                        />
                      </div>
                      <div class="featured-teaser">
                        <img
                          src="/images/projects/range/image4.png"
                          alt="Range mobile event history screenshot"
                          loading="lazy"
                        />
                      </div>
                    </div>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="home-apps" class="section section--split">
      <div class="section-heading">
        <p class="eyebrow">Home apps</p>
        <h2>Private tools for everyday life</h2>
        <p>Apps designed around actual household needs, not demo ideas.</p>
      </div>

      <ProjectGrid projects={homeApps} />
    </section>

    <section id="websites" class="section section--split">
      <div class="section-heading">
        <p class="eyebrow">Websites</p>
        <h2>Content-led sites and portfolios</h2>
        <p>Static sites with structure, storytelling and clean project data.</p>
      </div>

      <ProjectGrid projects={websites} />
    </section>

    <section id="embedded-tools" class="section section--split">
      <div class="section-heading">
        <p class="eyebrow">Embedded tools</p>
        <h2>Useful extras added to existing sites</h2>
        <p>
          Practical tools for improving customer journeys without rebuilding the
          whole website from scratch.
        </p>
      </div>

      <ProjectGrid projects={embeddedTools} />
    </section>

    <section id="next-build" class="section section--split next-panel">
      <div class="section-heading">
        <p class="eyebrow">Next build</p>
        <h2>Church database prototype</h2>
        <p>
          The next serious project is a simple, trustworthy church admin system
          for people, households, groups, reminders and pastoral notes. The aim
          is to show how much easier and safer the current process could be.
        </p>
      </div>

      <ProjectGrid projects={prototypes} />
    </section>

    <section id="contact" class="section contact-section">
      <div class="contact-section__content">
        <p class="eyebrow">Contact</p>
        <h2>Interested in the way I build practical tools?</h2>
        <p>
          This portfolio is a record of the apps, websites and small systems I
          have built around real problems. I’m always happy to talk about the
          thinking behind them, the technical choices, or where they could go
          next.
        </p>
      </div>

      <div class="contact-card">
        <h3>Get in touch</h3>
        <p>The easiest way to contact me is by email.</p>

        <a class="button button--primary" href="mailto:rosslyall99@gmail.com">
          Email Ross
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

---
const { project } = Astro.props;

type LiveLink = {
  label: string;
  url: string;
};

const liveLinks: LiveLink[] = Array.isArray(project.links?.live)
  ? project.links.live
  : project.links?.live
    ? [{ label: "Live site", url: project.links.live }]
    : [];

const hasLinks =
  project.links?.caseStudy ||
  liveLinks.length > 0 ||
  project.links?.privateLabel;
---

<article
  class={`project-card project-card--${project.theme} ${
    project.highlight ? "project-card--featured" : ""
  }`}
>
  <div class="project-visual" aria-hidden="true">
    {
      project.image ? (
        <img
          class="project-visual__image"
          src={project.image}
          alt={`${project.title} screenshot`}
          loading="lazy"
        />
      ) : (
        <>
          <span class="project-visual__orb" />
          <span class="project-visual__line" />
          <span class="project-visual__line project-visual__line--short" />
        </>
      )
    }
  </div>

  <div class="project-card__body">
    <div class="project-card__top">
      <span class="project-category">{project.category}</span>
      <span class="project-status">{project.status}</span>
    </div>

    <h3>{project.title}</h3>
    <p class="project-type">{project.type}</p>
    <p class="project-description">{project.description}</p>

    <div
      class="tech-list"
      aria-label={`Technologies used for ${project.title}`}
    >
      {project.tech.map((item: string) => <span>{item}</span>)}
    </div>

    {
      hasLinks && (
        <div class="project-actions">
          {project.links?.caseStudy && (
            <a
              class="project-link project-link--primary"
              href={project.links.caseStudy}
            >
              Read case study
            </a>
          )}

          {liveLinks.map((link) => (
            <a
              class="project-link"
              href={link.url}
              target="_blank"
              rel="noreferrer"
            >
              {link.label}
            </a>
          ))}

          {project.links?.privateLabel && (
            <span
              class="project-link project-link--disabled"
              aria-disabled="true"
            >
              {project.links.privateLabel}
            </span>
          )}
        </div>
      )
    }
  </div>
</article>
